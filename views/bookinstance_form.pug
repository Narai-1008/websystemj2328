extends layout

block content
  h1=title

  form(method='POST')
    div.form-group
      label(for='book') 本:
      select#book.form-control(name='book' required)
        option(value='') --本を選択してください--
        for book in book_list
          if selected_book==book._id.toString()
            option(value=book._id, selected) #{book.title}
          else
            option(value=book._id) #{book.title}

    div.form-group
      label(for='imprint') 出版社情報:
      input#imprint.form-control(type='text' placeholder='出版社と日付情報' name='imprint' required value=(undefined===bookinstance ? '' : bookinstance.imprint) )
    div.form-group
      label(for='due_back') 返却予定日:
      input#due_back.form-control(type='date' name='due_back' value=(undefined===bookinstance ? '' : bookinstance.due_back_yyyy_mm_dd))

    div.form-group
      label(for='status') 状態:
      select#status.form-control(name='status' required)
        option(value='') --状態を選択してください--
        each status in [{value:'Maintenance',label:'保守中'},{value:'Available',label:'利用可能'},{value:'Loaned',label:'貸出中'},{value:'Reserved',label:'予約済み'}]
          if undefined===bookinstance || bookinstance.status!=status.value
            option(value=status.value)= status.label
          else
            option(value=status.value selected)= status.label

    button.btn.btn-primary(type='submit') 送信

  if errors
    ul
      for error in errors
        li!= error.msg
